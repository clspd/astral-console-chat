{
  "name": "astral-console-chat",
  "version": "0.0.0-alpha.8",
  "description": "A console chat client",
  "keywords": [
    "back-end",
    "cli",
    "tui",
    "chat",
    "llm",
    "ai"
  ],
  "license": "AGPL-3.0",
  "author": "chcs1013",
  "type": "module",
  "main": "index.js",
  "bin": {
    "astral-console-chat": "dist/cli.js"
  },
  "files": [
    ".gitignore",
    ".github/**/*",
    ".scripts/**/*",
    "src/**",
    "dist/**",
    "postinstall.js",
    "prepare.mjs",
    "tsconfig.json",
    "tsdown.config.ts",
    "banner.mjs",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node postinstall.js",
    "test": "echo \"Error: no test specified\" && exit 0",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,mjs,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,mjs,js}\"",
    "build": "pnpm run type-check && pnpm run build-only",
    "build-only": "tsdown",
    "start": "node dist/cli.js"
  },
  "homepage": "https://github.com/clspd/astral-console-chat#readme",
  "bugs": {
    "url": "https://github.com/clspd/astral-console-chat/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clspd/astral-console-chat.git"
  },
  "packageManager": "pnpm",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.45",
    "ai": "~6.0.174",
    "ink": "~7.0.1",
    "ink-text-input": "~6.0.0",
    "json5": "~2.2.3",
    "lodash.clonedeep": "^4.5.0",
    "lz-string": "^1.5.0",
    "react": "~19.2.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/lodash.clonedeep": "~4.5.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "only-allow": "~1.2.2"
  }
}
